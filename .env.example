# NEXT_PUBLIC_APP_URL - REQUIRED: Set to your Vercel deployment URL
# Used for password reset email links and other absolute URLs
# Example: "https://your-project.vercel.app"
# NEXT_PUBLIC_APP_URL=""

# NEXT_PUBLIC_BASE_URL - REQUIRED: Same as APP_URL for most deployments
# Used for redirect URLs after logout
# NEXT_PUBLIC_BASE_URL=""

# JWT_SECRET - REQUIRED: Secret key for signing auth tokens
# Generate with: openssl rand -hex 32
JWT_SECRET="change-this-to-a-random-secret-in-production"

# Google OAuth (optional - for Google login)
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""
# GOOGLE_REDIRECT_URI=""

# SMTP Email (optional - for password reset emails)
# SMTP_HOST=""
# SMTP_PORT=587
# SMTP_USER=""
# SMTP_PASS=""
# SMTP_FROM="noreply@ias.rw"

# Turso Database (required for Vercel — persistent SQLite-compatible serverless DB)
# Sign up at https://turso.tech, create a database, and get the URL + auth token
# TURSO_DB_URL="libsql://your-db-name.turso.io"
# TURSO_AUTH_TOKEN="your-auth-token"
